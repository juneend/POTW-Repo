      value: Girl
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[1].speaker
      value: You
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[2].speaker
      value: Girl
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[0].dialogue
      value: "\u201CStick close, buddy. We\u2019ve crossed the city boundaries. Look
        how clean everything is\u2026 it\u2019s like the heatwave isn\u2019t even
        happening here.\u201D\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[1].dialogue
      value: '"Coo."'
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[2].dialogue
      value: "\u201CYeah, the air even smells expensive. And there\u2019s guards
        everywhere; be careful. We need to get to Alex\u2019s office fast.\u201D"
      objectReference: {fileID: 0}
    - target: {fileID: 6384596258644641706, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: m_Name
