    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[0].dialogue
      value: "\u201CRations and lettuce. That\u2019ll be 40 credits.\u201D\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[1].dialogue
      value: "\u201CFourty?! It was twenty just yesterday, I swear. The heatwave
        hasn't even hit its peak yet for the season?\u201D\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[2].dialogue
      value: "\"AC taxes went up again, kid. You payin\u2019 or starvin\u2019?\u201D\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
