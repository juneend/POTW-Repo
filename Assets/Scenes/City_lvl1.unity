PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[0].speaker
      value: Girl
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[1].speaker
      value: Girl
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[2].speaker
      value: You
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[3].speaker
      value: Girl
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[0].dialogue
      value: " \u201CAlright\u2026 Stay close. We just need to grab some ground beef,
        and whatever wilted greens are left at the market. If the heat didn\u2019t
        spoil them, the ration prices might.\u201D"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[1].dialogue
      value: "\u201CShould we check the fruit stand? \u2026Actually, forget it, 
        I heard the corporate farm runoff poisoned the last batch anyway.\u201D"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[2].dialogue
      value: "\u201CCoo.\u201D"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[3].dialogue
      value: "\u201CYeah, let\u2019s not risk it. The market's just ahead.\u201D\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 6384596258644641706, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: m_Name
      value: NPC
      objectReference: {fileID: 0}
