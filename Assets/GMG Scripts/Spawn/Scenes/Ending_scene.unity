    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[6].speaker
      value: Girl
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[7].speaker
      value: You
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[8].speaker
      value: Townsperson
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[9].speaker
      value: Girl
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[0].dialogue
      value: "\u201CHey! Alex\u2019s supply truck just passed through the checkpoint
        gates! How long until the rest of the solar-drip supplies arrive?\u201D\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[0].portrait
      value: 
      objectReference: {fileID: -3676964228572628897, guid: 6e3b42946e4abdc4c8d131728ac3a19e, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[10].speaker
      value: You
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[11].speaker
      value: Girl
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[12].speaker
      value: You
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[13].speaker
      value: Girl
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[14].speaker
      value: You
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[15].speaker
      value: Girl
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[16].speaker
      value: Mother
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[17].speaker
      value: Girl
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[18].speaker
      value: Mother
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[19].speaker
      value: Girl
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[1].dialogue
      value: "\u201CBy Friday. Once those land, we can finish retrofitting the remaining
        units on this block.\u201D"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[1].portrait
      value: 
      objectReference: {fileID: 1926693725549596516, guid: fb03058050339ea4c89d4302cf2901db, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[20].speaker
      value: Mother
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[21].speaker
      value: Mother
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[22].speaker
      value: You
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[23].speaker
      value: Mother
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[24].speaker
      value: Girl
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[25].speaker
      value: You
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[2].dialogue
      value: "\u201CFriday\u2026 I\u2019ll go tell the others.\u201D"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[2].portrait
      value: 
      objectReference: {fileID: -3676964228572628897, guid: 6e3b42946e4abdc4c8d131728ac3a19e, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[3].dialogue
      value: "\u201CYou know\u2026 when the heat wave hit last week, most of us thought
        we were just waiting for the city to let us burn.\u201D\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[3].portrait
      value: 
      objectReference: {fileID: -3676964228572628897, guid: 6e3b42946e4abdc4c8d131728ac3a19e, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[4].dialogue
      value: "\u201CNo one\u2019s coming to save us from the outside. We have to
        keep each other cool.\u201D\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[4].portrait
      value: 
      objectReference: {fileID: 1926693725549596516, guid: fb03058050339ea4c89d4302cf2901db, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[5].dialogue
      value: "\u201CThanks to you and Tam, we actually stand a chance. Truely\u2026
        thank you.\u201D\r\n\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[5].portrait
      value: 
      objectReference: {fileID: -3676964228572628897, guid: 6e3b42946e4abdc4c8d131728ac3a19e, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[6].dialogue
      value: "\u201CWe did it together.\u201D\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[6].portrait
      value: 
      objectReference: {fileID: 1926693725549596516, guid: fb03058050339ea4c89d4302cf2901db, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[7].dialogue
      value: "\u201CCoo, coo.\u201D\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[7].portrait
      value: 
      objectReference: {fileID: -642357303508060665, guid: 537f836a5a512bb488cc5476c6755e98, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[8].dialogue
      value: "\u201CAlright, well, back to work, then. See you at sunset!\u201D\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[8].portrait
      value: 
      objectReference: {fileID: -3676964228572628897, guid: 6e3b42946e4abdc4c8d131728ac3a19e, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[9].dialogue
      value: "\u201CSee you later!\u201D\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[9].portrait
      value: 
      objectReference: {fileID: 1926693725549596516, guid: fb03058050339ea4c89d4302cf2901db, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[10].dialogue
      value: '"Coo."'
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[10].portrait
      value: 
      objectReference: {fileID: -642357303508060665, guid: 537f836a5a512bb488cc5476c6755e98, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[11].dialogue
      value: "\u201CWe really did it, didn\u2019t we?\u201D"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[11].portrait
      value: 
      objectReference: {fileID: 1926693725549596516, guid: fb03058050339ea4c89d4302cf2901db, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[12].dialogue
      value: '"Coo, coo."'
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[12].portrait
      value: 
      objectReference: {fileID: -642357303508060665, guid: 537f836a5a512bb488cc5476c6755e98, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[13].dialogue
      value: "\u201CI know you\u2019re just a little pigeon\u2026 but when everyone
        else looked away, you stayed. And helped. And for that, I thank you.\u201D"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[13].portrait
      value: 
      objectReference: {fileID: 1926693725549596516, guid: fb03058050339ea4c89d4302cf2901db, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[14].dialogue
      value: '"Coo."'
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[14].portrait
      value: 
      objectReference: {fileID: -642357303508060665, guid: 537f836a5a512bb488cc5476c6755e98, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[15].dialogue
      value: "\u201COr you just stayed because I fixed your wing and fed you. Either
        way, thanks.\u201D\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[15].portrait
      value: 
      objectReference: {fileID: 1926693725549596516, guid: fb03058050339ea4c89d4302cf2901db, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[16].dialogue
      value: "\u201CI\u2019m glad everyone\u2019s finally together.\u201D"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[16].portrait
      value: 
      objectReference: {fileID: 1638969219849453209, guid: 15cfbc1201a107b47873877f21c27278, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[17].dialogue
      value: "\u201CMother, you\u2019re outside. How are you feeling?\u201D"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[17].portrait
      value: 
      objectReference: {fileID: 1926693725549596516, guid: fb03058050339ea4c89d4302cf2901db, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[18].dialogue
      value: "\u201CBetter now that the good news reached me.\u201D"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[18].portrait
      value: 
      objectReference: {fileID: 1638969219849453209, guid: 15cfbc1201a107b47873877f21c27278, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[19].dialogue
      value: "\u201CIt\u2019s working, Mom. Alex\u2019s grant came through and the
        whole block is helping build.\u201D "
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[19].portrait
      value: 
      objectReference: {fileID: 1926693725549596516, guid: fb03058050339ea4c89d4302cf2901db, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[20].dialogue
      value: "\u201CIt started with a blueprint, sweetie\u2026 but it took a lot
        of steps to get there.\u201D"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[20].portrait
      value: 
      objectReference: {fileID: 1638969219849453209, guid: 15cfbc1201a107b47873877f21c27278, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[21].dialogue
      value: "\u201CAnd a very stubborn little messenger.\u201D"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[21].portrait
      value: 
      objectReference: {fileID: 1638969219849453209, guid: 15cfbc1201a107b47873877f21c27278, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[22].dialogue
      value: '"Coo, coo!"'
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[22].portrait
      value: 
      objectReference: {fileID: -642357303508060665, guid: 537f836a5a512bb488cc5476c6755e98, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[23].dialogue
      value: "\u201CThe rest of the city beyond that wall might take a long time
        to change. But small steps like this are what make progress.\u201D"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[23].portrait
      value: 
      objectReference: {fileID: 1638969219849453209, guid: 15cfbc1201a107b47873877f21c27278, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[24].dialogue
      value: "\u201CAnd communities like this are how we build our future. And you,
        little guy.\u201D"
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[24].portrait
      value: 
      objectReference: {fileID: 1926693725549596516, guid: fb03058050339ea4c89d4302cf2901db, type: 3}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[25].dialogue
      value: '"Coo!"'
      objectReference: {fileID: 0}
    - target: {fileID: 6265409806070484025, guid: 0d8a15d08ff259a49a85dfdfee2e1838, type: 3}
      propertyPath: Lines.Array.data[25].portrait
      value: 
      objectReference: {fileID: -642357303508060665, guid: 537f836a5a512bb488cc5476c6755e98, type: 3}
